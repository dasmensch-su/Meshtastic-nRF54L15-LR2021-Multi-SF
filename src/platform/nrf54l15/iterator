/* iterator — Minimal stub for Zephyr nRF54L15 port. */
#pragma once
#include <stddef.h>
namespace std {
    template <typename Iter>
    Iter next(Iter it, int n = 1) { while (n-- > 0) ++it; return it; }
    template <typename Iter>
    Iter prev(Iter it, int n = 1) { while (n-- > 0) --it; return it; }

    template <typename C>
    auto begin(C &c) -> decltype(c.begin()) { return c.begin(); }
    template <typename C>
    auto end(C &c) -> decltype(c.end()) { return c.end(); }
    template <typename T, size_t N>
    T *begin(T (&arr)[N]) { return arr; }
    template <typename T, size_t N>
    T *end(T (&arr)[N]) { return arr + N; }
}
