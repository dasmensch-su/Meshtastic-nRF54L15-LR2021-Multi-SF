/* Minimal std::deque stub for nRF54L15 Zephyr — backed by std::vector */
#pragma once
#include <vector>
#include <iterator>

namespace std {

template <typename T, typename Alloc = void>
class deque {
    vector<T> v_;
public:
    using value_type = T;
    using size_type = size_t;
    using reference = T&;
    using const_reference = const T&;
    using iterator = typename vector<T>::iterator;
    using const_iterator = typename vector<T>::const_iterator;

    /* Minimal reverse_iterator wrapper */
    class reverse_iterator {
        T *ptr_;
    public:
        reverse_iterator(T *p) : ptr_(p) {}
        T &operator*() { return *(ptr_ - 1); }
        T *operator->() { return ptr_ - 1; }
        reverse_iterator &operator++() { --ptr_; return *this; }
        reverse_iterator operator++(int) { reverse_iterator tmp = *this; --ptr_; return tmp; }
        reverse_iterator &operator--() { ++ptr_; return *this; }
        bool operator!=(const reverse_iterator &o) const { return ptr_ != o.ptr_; }
        bool operator==(const reverse_iterator &o) const { return ptr_ == o.ptr_; }
        T *base() const { return ptr_; }
    };

    deque() = default;
    size_type size() const { return v_.size(); }
    bool empty() const { return v_.empty(); }
    reference front() { return v_.front(); }
    const_reference front() const { return v_.front(); }
    reference back() { return v_.back(); }
    const_reference back() const { return v_.back(); }
    void push_back(const T& val) { v_.push_back(val); }
    void push_back(T&& val) { v_.push_back(static_cast<T&&>(val)); }
    void push_front(const T& val) { v_.insert(v_.begin(), val); }
    void pop_front() { if (!v_.empty()) v_.erase(v_.begin()); }
    void pop_back() { if (!v_.empty()) v_.pop_back(); }
    void clear() { v_.clear(); }
    iterator begin() { return v_.begin(); }
    iterator end() { return v_.end(); }
    const_iterator begin() const { return v_.begin(); }
    const_iterator end() const { return v_.end(); }
    reverse_iterator rbegin() { return reverse_iterator(v_.data() + v_.size()); }
    reverse_iterator rend()   { return reverse_iterator(v_.data()); }
    reference operator[](size_type i) { return v_[i]; }
    const_reference operator[](size_type i) const { return v_[i]; }

    void swap(deque &other) { v_.swap(other.v_); }

    template <typename... Args>
    T &emplace_back(Args&&... args) {
        return v_.emplace_back(static_cast<Args&&>(args)...);
    }

    iterator erase(iterator pos) { return v_.erase(pos); }
    iterator erase(iterator first, iterator last) { return v_.erase(first, last); }
};

} // namespace std
